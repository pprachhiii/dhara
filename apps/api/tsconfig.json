{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",                    // ✅ Force CommonJS (fixes import issues)
    "moduleResolution": "node",
    "esModuleInterop": true,                 // ✅ This must be true
    "allowSyntheticDefaultImports": true,   // ✅ Helps with Express, etc.
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": "./src",
    "outDir": "dist"
  },
  "include": ["src"]
}
